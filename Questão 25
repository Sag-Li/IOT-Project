#include <stdio.h>

int main() {
    int valor;
    int consecutivas = 0;

    while (1) {
        scanf("%d", &valor);

        if (valor == -1) {
            break;
        }

        if (valor > 600) {
            consecutivas++;
        } else {
            consecutivas = 0;
        }

        if (consecutivas == 3) {
            printf("ALARME\n");
            consecutivas = 0;
        }
    }

    return 0;
}
