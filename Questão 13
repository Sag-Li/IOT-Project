#include <stdio.h>

int main() {
    int vetor[10];
    int i, aux;

    for (i = 0; i < 10; i++) {
        printf("Digite o valor %d: ", i + 1);
        scanf("%d", &vetor[i]);
    }

    for (i = 0; i < 5; i++) {
        aux = vetor[i];
        vetor[i] = vetor[9 - i];
        vetor[9 - i] = aux;
    }

    printf("Vetor invertido: ");
    for (i = 0; i < 10; i++) {
        printf("%d ", vetor[i]);
    }
    printf("\n");

    return 0;
}
