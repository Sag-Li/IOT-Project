#include <stdio.h>

int main() {
    float numero;
    float soma = 0.0;
    int contador = 0;

    while (1) {
        printf("Digite um número (ou 0 para sair): ");
        scanf("%f", &numero);

        if (numero == 0) {
            break;
        }

        soma += numero;
        contador++;
    }

    printf("A soma total é: %.2f\n", soma);

    if (contador > 0) {
        printf("A média é: %.2f\n", soma / contador);
    } else {
        printf("Nenhum número foi digitado além do zero.\n");
    }

    return 0;
}
