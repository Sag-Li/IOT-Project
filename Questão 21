#include <stdio.h>

int main() {
    int paginas;

    while (1) {
        scanf("%d", &paginas);

        if (paginas == -1) {
            break;
        }

        if (paginas > 500) {
            printf("Leitura longa\n");
        } else {
            printf("Leitura curta\n");
        }
    }

    return 0;
}
