#include <stdio.h>

int main() {
    int opcao;
    float valor, soma = 0, maior = 0;
    int contador = 0;

    while (1) {
        printf("\n--- MENU ---\n");
        printf("1 -> Inserir valor\n");
        printf("2 -> Mostrar média\n");
        printf("3 -> Mostrar maior\n");
        printf("4 -> Sair\n");
        printf("Escolha uma opção: ");
        scanf("%d", &opcao);

        if (opcao == 4) {
            printf("Saindo...\n");
            break;
        }

        if (opcao == 1) {
            printf("Digite um valor: ");
            scanf("%f", &valor);
            soma += valor;
            if (contador == 0 || valor > maior) {
                maior = valor;
            }
            contador++;
        } else if (opcao == 2) {
            if (contador > 0) {
                printf("Média atual: %.2f\n", soma / contador);
            } else {
                printf("Nenhum valor foi inserido ainda.\n");
            }
        } else if (opcao == 3) {
            if (contador > 0) {
                printf("Maior valor atual: %.2f\n", maior);
            } else {
                printf("Nenhum valor foi inserido ainda.\n");
            }
        } else {
            printf("Opção inválida!\n");
        }
    }

    return 0;
}
