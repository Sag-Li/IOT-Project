#include <stdio.h>

int main() {
    int numero;
    int maior;
    int primeiro = 1;

    printf("Digite vários números (ou um negativo para parar):\n");

    while (1) {
        scanf("%d", &numero);

        if (numero < 0) {
            break;
        }

        if (primeiro == 1) {
            maior = numero;
            primeiro = 0;
        } else if (numero > maior) {
            maior = numero;
        }
    }

    if (primeiro == 0) {
        printf("Maior número digitado: %d\n", maior);
    } else {
        printf("Nenhum número válido foi digitado.\n");
    }

    return 0;
}
