#include <stdio.h>

int main() {
    int numero, i;
    int divisores = 0;

    printf("Digite um número: ");
    scanf("%d", &numero);

    for (i = 1; i <= numero; i++) {
        if (numero % i == 0) {
            divisores++;
        }
    }

    if (divisores == 2) {
        printf("O número %d é primo.\n", numero);
    } else {
        printf("O número %d não é primo.\n", numero);
    }

    return 0;
}
