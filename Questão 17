#include <stdio.h>

int eprimo(int numero) {
    if (numero <= 1) {
        return 0;
    }
    for (int i = 2; i * i <= numero; i++) {
        if (numero % i == 0) {
            return 0;
        }
    }
    return 1;
}

int main() {
    int num;
    printf("Digite um número: ");
    scanf("%d", &num);

    if (eprimo(num)) {
        printf("O número %d é primo.\n", num);
    } else {
        printf("O número %d não é primo.\n", num);
    }

    return 0;
}
