#include <stdio.h>

int main() {
    int vetor[10];
    int i;
    int crescente = 1;

    for (i = 0; i < 10; i++) {
        printf("Digite o valor %d: ", i + 1);
        scanf("%d", &vetor[i]);
    }

    for (i = 0; i < 9; i++) {
        if (vetor[i] > vetor[i + 1]) {
            crescente = 0;
            break;
        }
    }

    if (crescente == 1) {
        printf("O vetor está em ordem crescente.\n");
    } else {
        printf("O vetor não está em ordem crescente.\n");
    }

    return 0;
}
