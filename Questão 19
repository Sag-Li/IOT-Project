#include <stdio.h>

int encontrarMaior(int vetor[], int tamanho) {
    int maior = vetor[0];
    for (int i = 1; i < tamanho; i++) {
        if (vetor[i] > maior) {
            maior = vetor[i];
        }
    }
    return maior;
}

int main() {
    int Mvetor;

    for (int i = 0; i < 10; i++) {
        printf("Digite o valor %d: ", i + 1);
        scanf("%d", &Mvetor[i]);
    }

    int maior = encontrarMaior(Mvetor, 10);
    printf("O maior valor do vetor é: %d\n", maior);

    return 0;
}
