#include <stdio.h>

int main() {
    float leituras[5];
    float soma = 0;
    float media;
    int i;
    int risco = 0;

    for (i = 0; i < 5; i++) {
        scanf("%f", &leituras[i]);
        soma += leituras[i];
        if (leituras[i] > 35) {
            risco = 1;
        }
    }

    media = soma / 5.0;
    printf("%.2f\n", media);

    if (risco == 1) {
        printf("RISCO\n");
    }

    return 0;
}
