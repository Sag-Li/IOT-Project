#include <stdio.h>

int main() {
    float vetor[10];
    float soma = 0;
    float media;
    int i;
    int contagem = 0;

    for (i = 0; i < 10; i++) {
        printf("Digite o valor %d: ", i + 1);
        scanf("%f", &vetor[i]);
        soma += vetor[i];
    }

    media = soma / 10.0;

    for (i = 0; i < 10; i++) {
        if (vetor[i] > media) {
            contagem++;
        }
    }

    printf("Media do vetor: %.2f\n", media);
    printf("Valores acima da media: %d\n", contagem);

    return 0;
}
