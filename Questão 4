#include <stdio.h>

int main() {
    int numero;

    printf("Digite um número inteiro: ");
    scanf("%d", &numero);

    if (numero % 3 == 0 && numero % 5 == 0) {
        printf("O número é multiplo de 3 e 5 ao mesmo tempo.\n");
    } else if (numero % 3 == 0 && numero % 5 != 0) {
        printf("Ele é múltiplo apenas de 3.\n");
    } else if (numero % 5 == 0 && numero % 3 != 0) {
        printf("Ele é múltiplo apenas de 5.\n");
    } else {
        printf("Ele não é múltiplo nem de 3 nem de 5.\n");
    }

    return 0;
}
